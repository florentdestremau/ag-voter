<div class="waiting-room" id="waiting_room">
  <div class="waiting-room-content">
    <div class="waiting-room-icon">⏳</div>
    <h2>Salle d'attente</h2>
    <p class="waiting-room-message">
      La session <strong><%= @ag_session.name %></strong> n'a pas encore commencé.
    </p>
    <p class="waiting-room-status">
      Jouez à 2048 en attendant le démarrage...
    </p>

    <div class="game-container">
      <div class="game-info">
        <div class="score-container">
          <span>Score:</span>
          <span id="score">0</span>
        </div>
        <button id="game-reset" class="game-button">Nouveau jeu</button>
      </div>
      <div id="game-board" class="game-board"></div>
      <p class="game-instructions">
        Utilisez les flèches du clavier pour déplacer les tuiles
      </p>
    </div>
  </div>
</div>

<style>
  .waiting-room {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
  }

  .waiting-room-content {
    padding: 2rem;
    border-radius: 12px;
    background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    max-width: 500px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .waiting-room-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
    animation: bounce 1s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .waiting-room-content h2 {
    margin: 1rem 0;
    color: #2c3e50;
    font-size: 1.5rem;
  }

  .waiting-room-message {
    margin: 1rem 0;
    color: #34495e;
    font-size: 1rem;
  }

  .waiting-room-status {
    margin: 1rem 0;
    color: #7f8c8d;
    font-size: 0.9rem;
    font-style: italic;
  }

  .game-container {
    margin-top: 1.5rem;
    text-align: center;
  }

  .game-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    padding: 0.5rem;
    background: rgba(255, 255, 255, 0.8);
    border-radius: 8px;
  }

  .score-container {
    display: flex;
    gap: 0.5rem;
    font-weight: bold;
    color: #2c3e50;
  }

  .game-button {
    padding: 0.5rem 1rem;
    background: #3498db;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-weight: bold;
    transition: background 0.3s;
  }

  .game-button:hover {
    background: #2980b9;
  }

  .game-board {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-gap: 6px;
    background: #bbada0;
    border-radius: 6px;
    padding: 6px;
    width: 280px;
    height: 280px;
    margin: 0 auto;
  }

  .game-tile {
    background: #cdc1b4;
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 2.5rem;
    color: #776e65;
    transition: all 0.15s ease-in-out;
    position: relative;
    width: 100%;
    height: 100%;
    min-width: 60px;
    min-height: 60px;
  }

  .game-tile.new {
    animation: pop 0.2s;
  }

  .game-tile[data-value="2"] { background: #eee4da; color: #776e65; }
  .game-tile[data-value="4"] { background: #ede0c8; color: #776e65; }
  .game-tile[data-value="8"] { background: #f2b179; color: #f9f6f2; }
  .game-tile[data-value="16"] { background: #f59563; color: #f9f6f2; }
  .game-tile[data-value="32"] { background: #f67c5f; color: #f9f6f2; }
  .game-tile[data-value="64"] { background: #f65e3b; color: #f9f6f2; }
  .game-tile[data-value="128"] { background: #edcf72; color: #095f6b; font-size: 2rem; }
  .game-tile[data-value="256"] { background: #edcc61; color: #095f6b; font-size: 2rem; }
  .game-tile[data-value="512"] { background: #edc850; color: #095f6b; font-size: 2rem; }
  .game-tile[data-value="1024"] { background: #edc53f; color: #095f6b; font-size: 1.5rem; }
  .game-tile[data-value="2048"] { background: #edc22e; color: #095f6b; font-size: 1.5rem; }
  .game-tile[data-value="4096"] { background: #3c3322; color: #f9f6f2; font-size: 1.5rem; }

  @keyframes pop {
    0% { transform: scale(0.5); }
    50% { transform: scale(1.1); }
    100% { transform: scale(1); }
  }

  .game-instructions {
    margin-top: 1rem;
    color: #7f8c8d;
    font-size: 0.85rem;
  }

  @media (max-width: 768px) {
    .waiting-room-content {
      max-width: 95%;
      padding: 1rem;
    }

    .waiting-room-icon {
      font-size: 3rem;
      margin-bottom: 0.5rem;
    }

    .waiting-room-content h2 {
      font-size: 1.2rem;
      margin: 0.5rem 0;
    }

    .game-info {
      flex-direction: column;
      gap: 0.5rem;
      margin-bottom: 0.5rem;
    }

    .game-board {
      width: 240px;
      height: 240px;
      padding: 4px;
      grid-gap: 4px;
    }

    .game-tile {
      min-width: 52px;
      min-height: 52px;
      font-size: 1.8rem;
    }

    .game-tile[data-value="128"],
    .game-tile[data-value="256"],
    .game-tile[data-value="512"] {
      font-size: 1.4rem;
    }

    .game-tile[data-value="1024"],
    .game-tile[data-value="2048"],
    .game-tile[data-value="4096"] {
      font-size: 1.1rem;
    }

    .game-button {
      padding: 0.4rem 0.8rem;
      font-size: 0.9rem;
    }

    .game-instructions {
      font-size: 0.75rem;
      margin-top: 0.5rem;
    }
  }

  @media (max-width: 480px) {
    .waiting-room-content {
      max-width: 98%;
      padding: 0.8rem;
    }

    .waiting-room-icon {
      font-size: 2.5rem;
      margin-bottom: 0.25rem;
    }

    .waiting-room-content h2 {
      font-size: 1rem;
      margin: 0.25rem 0;
    }

    .waiting-room-message,
    .waiting-room-status {
      font-size: 0.9rem;
      margin: 0.5rem 0;
    }

    .game-info {
      padding: 0.25rem;
      gap: 0.25rem;
    }

    .score-container {
      gap: 0.25rem;
      font-size: 0.9rem;
    }

    .game-board {
      width: 200px;
      height: 200px;
      padding: 3px;
      grid-gap: 3px;
    }

    .game-tile {
      min-width: 44px;
      min-height: 44px;
      font-size: 1.4rem;
    }

    .game-tile[data-value="128"],
    .game-tile[data-value="256"],
    .game-tile[data-value="512"] {
      font-size: 1.1rem;
    }

    .game-tile[data-value="1024"],
    .game-tile[data-value="2048"],
    .game-tile[data-value="4096"] {
      font-size: 0.9rem;
    }

    .game-button {
      padding: 0.3rem 0.6rem;
      font-size: 0.8rem;
    }
  }
</style>

<script>
  class Game2048 {
    constructor(boardElement, scoreElement, resetButton) {
      this.boardElement = boardElement;
      this.scoreElement = scoreElement;
      this.resetButton = resetButton;
      this.grid = [];
      this.score = 0;

      this.init();
      this.bindEvents();
    }

    init() {
      this.grid = Array(4).fill(null).map(() => Array(4).fill(0));
      this.score = 0;
      this.addNewTile();
      this.addNewTile();
      this.render();
    }

    addNewTile() {
      const empty = [];
      for (let i = 0; i < 4; i++) {
        for (let j = 0; j < 4; j++) {
          if (this.grid[i][j] === 0) empty.push({x: i, y: j});
        }
      }
      if (empty.length > 0) {
        const pos = empty[Math.floor(Math.random() * empty.length)];
        this.grid[pos.x][pos.y] = Math.random() < 0.9 ? 2 : 4;
      }
    }

    move(direction) {
      let moved = false;
      const original = this.grid.map(r => [...r]);

      if (direction === 'left' || direction === 'right') {
        for (let i = 0; i < 4; i++) {
          this.grid[i] = this.moveLine(this.grid[i], direction === 'right');
        }
      } else {
        for (let j = 0; j < 4; j++) {
          const col = [this.grid[0][j], this.grid[1][j], this.grid[2][j], this.grid[3][j]];
          const moved_col = this.moveLine(col, direction === 'down');
          for (let i = 0; i < 4; i++) {
            this.grid[i][j] = moved_col[i];
          }
        }
      }

      for (let i = 0; i < 4; i++) {
        for (let j = 0; j < 4; j++) {
          if (original[i][j] !== this.grid[i][j]) {
            moved = true;
            break;
          }
        }
      }

      if (moved) {
        this.addNewTile();
        this.render();
      }
    }

    moveLine(line, reverse) {
      if (reverse) line = line.reverse();

      line = line.filter(val => val !== 0);

      for (let i = 0; i < line.length - 1; i++) {
        if (line[i] === line[i + 1]) {
          line[i] *= 2;
          this.score += line[i];
          line.splice(i + 1, 1);
          i++;
        }
      }

      while (line.length < 4) line.push(0);

      if (reverse) line = line.reverse();
      return line;
    }

    render() {
      this.boardElement.innerHTML = '';
      for (let i = 0; i < 4; i++) {
        for (let j = 0; j < 4; j++) {
          const value = this.grid[i][j];
          const tile = document.createElement('div');
          tile.className = 'game-tile';
          if (value > 0) {
            tile.setAttribute('data-value', value);
            tile.textContent = value;
            tile.classList.add('new');
          }
          this.boardElement.appendChild(tile);
        }
      }
      this.scoreElement.textContent = this.score;
    }

    bindEvents() {
      document.addEventListener('keydown', (e) => {
        const keys = {
          'ArrowLeft': 'left',
          'ArrowRight': 'right',
          'ArrowUp': 'up',
          'ArrowDown': 'down'
        };
        if (keys[e.key]) {
          e.preventDefault();
          this.move(keys[e.key]);
        }
      });

      let touchStartX = 0;
      let touchStartY = 0;

      this.boardElement.addEventListener('touchstart', (e) => {
        const touch = e.touches[0];
        touchStartX = touch.clientX;
        touchStartY = touch.clientY;
      });

      this.boardElement.addEventListener('touchend', (e) => {
        const touch = e.changedTouches[0];
        const touchEndX = touch.clientX;
        const touchEndY = touch.clientY;

        const dx = touchEndX - touchStartX;
        const dy = touchEndY - touchStartY;
        const threshold = 30;

        if (Math.abs(dx) > threshold && Math.abs(dy) < threshold) {
          e.preventDefault();
          this.move(dx > 0 ? 'right' : 'left');
        } else if (Math.abs(dy) > threshold && Math.abs(dx) < threshold) {
          e.preventDefault();
          this.move(dy > 0 ? 'down' : 'up');
        }
      });

      this.resetButton.addEventListener('click', () => this.init());
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const boardElement = document.getElementById('game-board');
    const scoreElement = document.getElementById('score');
    const resetButton = document.getElementById('game-reset');

    if (boardElement && scoreElement && resetButton) {
      new Game2048(boardElement, scoreElement, resetButton);
    }
  });
</script>

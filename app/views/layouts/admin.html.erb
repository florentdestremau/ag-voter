<!DOCTYPE html>
<html>
  <head>
    <title>Admin AG - <%= content_for(:title) || "Votes" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="admin-nav">
      <a href="<%= admin_root_path %>">Sessions AG</a>
      <%= button_to "Déconnexion", admin_logout_path, method: :delete, class: "btn-logout" %>
    </nav>

    <main>
      <% if notice %>
        <div class="flash flash-notice"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="flash flash-alert"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
